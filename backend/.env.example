NODE_ENV=development
PORT=3010

# Docker Postgres (port 5433 — WebApp uses 5432)
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/b2ccoop_accounting
DIRECT_URL=postgresql://postgres:postgres@localhost:5433/b2ccoop_accounting

# Staff JWT — use the same secret as WebApp Nest API for cross-app staff tokens
ADMIN_JWT_SECRET=change-me-to-a-secret-at-least-32-chars-long

# WebApp → Accounting machine posts (Bearer token alternative to staff JWT)
INTEGRATION_SERVICE_SECRET=change-me-integration-secret-at-least-32-chars

# Firebase Admin (same project as WebApp: b2ccoop-87114) — staff UI sign-in
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional CORS for accounting UI
CORS_ORIGIN=http://localhost:5174

# WebApp API — member lookup by name / B2C member ID (staff JWT forwarded)
WEBAPP_API_URL=http://localhost:3000
